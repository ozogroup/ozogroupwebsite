# Public browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only. Never expose this value to the browser or commit a real key.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Official production URL used for canonical URLs, sitemap, robots, and redirects.
NEXT_PUBLIC_SITE_URL=https://kiaskincare.in

# Optional comma-separated old domains that should redirect to the official domain.
LEGACY_DOMAINS=ozo-group.vercel.app

# Server-only Google Apps Script integration. Use deployment secrets for real values.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_APPS_SCRIPT_DEPLOYMENT_ID=YOUR_GOOGLE_APPS_SCRIPT_DEPLOYMENT_ID
GOOGLE_APPS_SCRIPT_LIBRARY_URL=https://script.google.com/macros/library/d/YOUR_LIBRARY_ID/YOUR_VERSION
# Recommended: configure the same secret in Apps Script project properties.
GOOGLE_APPS_SCRIPT_SECRET=YOUR_SHARED_WEBHOOK_SECRET

# Operational reset safety values. These are for local/server-side tooling only.
# Do not put destructive reset confirmations in Vercel production env unless a
# controlled reset run is actively being performed.
EXPECTED_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
RESET_CONFIRMATION=TYPE_RESET_KIA_OPERATIONAL_DATA_TO_RUN

# Future Razorpay placeholders. Leave unset until payment gateway integration.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
